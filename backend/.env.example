# ReviewAI Backend — Environment Variables
# Copy this to .env and fill in your values.

# ── Ollama (required) ──────────────────────────────────────────────────────
# URL of your running Ollama server (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Chat model for all 5 review agents.
# Recommended options (pull with `ollama pull <model>`):
#   qwen2.5-coder:7b   ← best for code tasks
#   llama3.2           ← good general model
#   mistral            ← fast and capable
#   codellama          ← code-specialized
OLLAMA_MODEL=llama3.2

# Embedding model for ChromaDB RAG.
# Run: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── GitHub (optional) ─────────────────────────────────────────────────────
# Personal Access Token for higher GitHub API rate limits (5000/hr vs 60/hr).
GITHUB_TOKEN=your_optional_github_pat_here

# ── App Config ────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
MAX_CODE_CHARS=20000
CORS_ORIGINS=["http://localhost:3000"]
